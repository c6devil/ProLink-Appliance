# ----------------------------------------------------------------------------
# ProLink Appliance Repair — environment variables
# Copy this file to `.env` and fill in real values.
# ----------------------------------------------------------------------------

# PostgreSQL connection string (Prisma 7 connects via the node-postgres adapter).
# Production: use your managed Postgres (Neon/Supabase), e.g.
#   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Local dev: run `npx prisma dev` and use the TCP url it prints, e.g.
#   postgresql://postgres:postgres@localhost:51214/postgres?sslmode=disable
DATABASE_URL="postgresql://postgres:postgres@localhost:51214/postgres?sslmode=disable"

# Admin account created/updated by `npm run db:seed`.
ADMIN_EMAIL="admin@prolinkappliancerepair.com"
ADMIN_PASSWORD="change-this-strong-password"

# Secret used to sign admin session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-long-random-secret"

# Email delivery (Resend). Leave RESEND_API_KEY empty to log emails to the
# console instead of sending them (useful in development).
RESEND_API_KEY=""
EMAIL_FROM="ProLink Appliance Repair <bookings@yourdomain.com>"
BOOKING_NOTIFICATION_EMAIL="owner@yourdomain.com"

# Public site configuration (safe to expose to the browser).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_BUSINESS_PHONE="(555) 555-0123"
