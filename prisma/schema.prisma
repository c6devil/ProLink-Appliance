// ProLink Appliance Repair — Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Lifecycle of a repair booking request.
enum BookingStatus {
  NEW
  CONTACTED
  SCHEDULED
  COMPLETED
  CANCELLED
}

/// Preferred arrival window selected by the customer.
enum TimeWindow {
  MORNING
  AFTERNOON
  EVENING
}

/// A repair appointment request submitted through the public booking form.
model Booking {
  id            String        @id @default(cuid())
  ref           String        @unique // human-friendly reference, e.g. PL-7F3K2A
  appliance     String
  brand         String?
  modelNo       String?
  problem       String
  name          String
  email         String
  phone         String
  addressLine   String
  city          String
  state         String
  zip           String
  preferredDate DateTime
  timeWindow    TimeWindow
  status        BookingStatus @default(NEW)
  notes         String? // internal admin notes
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// A service offering rendered as its own marketing/SEO page.
model Service {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String // key matching a React icon component
  shortDesc String
  longDesc  String
  symptoms  String[] // common problems we fix for this appliance
  featured  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

/// A geographic area we serve, rendered as a local-SEO landing page.
model ServiceArea {
  id        String   @id @default(cuid())
  city      String
  slug      String   @unique
  state     String
  blurb     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

/// A customer testimonial shown on the site.
model Testimonial {
  id        String   @id @default(cuid())
  author    String
  location  String
  rating    Int      @default(5) // 1..5
  body      String
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([published, order])
}

/// A message submitted through the contact form.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read, createdAt])
}

/// Admin user able to access the dashboard.
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}
